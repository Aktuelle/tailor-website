# ── Cloudinary ─────────────────────────────────────────────────────────────
# Your Cloudinary cloud name (visible in dashboard)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── CinetPay ───────────────────────────────────────────────────────────────
# Get these from your CinetPay merchant dashboard
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id

# ── Site URL ───────────────────────────────────────────────────────────────
# Your production domain (for CinetPay return URLs)
NEXT_PUBLIC_SITE_URL=https://votre-domaine.tg
